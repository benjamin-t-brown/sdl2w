{
  "name": "sdl2w",
  "version": "1.0.0",
  "description": "SDL2W - SDL2 Wrapper",
  "main": "lib.js",
  "scripts": {
    "dist": "http-server dist",
    "build": "npm run clean && mkdirp dist && npm run build-example && npm run mv-example && cp -rf public/* ./dist/",
    "build-example": "(cd ../example && make clean && make -j8 js)",
    "mv-example": "mv SDL2W_EXAMPLE.data SDL2W_EXAMPLE.wasm SDL2W_EXAMPLE.js ./dist/",
    "clean": "rm -rf dist"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/benjamin-t-brown/sdl2w.git"
  },
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/benjamin-t-brown/sdl2w/issues"
  },
  "homepage": "https://github.com/benjamin-t-brown/sdl2w#readme",
  "devDependencies": {
    "@eslint/js": "^9.26.0",
    "eslint": "^9.26.0",
    "globals": "^16.1.0",
    "http-server": "^14.1.1",
    "mkdirp": "^3.0.1"
  }
}
