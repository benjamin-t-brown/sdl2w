{
  "configurations": [
    {
      "name": "Win32",
      "includePath": ["${workspaceFolder}\\src"],
      "defines": [
        "_DEBUG",
        "UNICODE",
        "_UNICODE",
        "__LITTLE_ENDIAN__"
      ],
      "cStandard": "c17",
      "cppStandard": "c++23",
      "intelliSenseMode": "windows-gcc-x64",
      "compilerArgs": [
        "-Wall",
        "-Wextra",
        "-Werror",
        "-std=c++23",
        "-Werror",
        "-O0",
        "-I ./src",
        "-I ./src/deps"
      ],
      "compilerPath": "g++"
    }
  ],
  "version": 4
}
